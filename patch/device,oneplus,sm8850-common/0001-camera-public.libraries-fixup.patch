From 0434a9ea23a85fc09d12f834e6053ea752389db2 Mon Sep 17 00:00:00 2001
From: 1vivy <1vivy@tutanota.com>
Date: Sun, 14 Jun 2026 01:24:03 -0600
Subject: [PATCH 1/3] camera: public.libraries fixup

Expose the ArcSoft and QNN HTP helper libraries as vendor public libraries so the camera app's classloader namespace can dlopen them from /odm, enabling the ArcSoft couple-HDR/turbo/denoise and QNN DSP paths.

extract-files.py: add a vendor/etc/public.libraries.txt blob_fixup listing the ArcSoft couple-HDR/turbo/denoise libraries, libarcsoft_qnnhtp.so, and the QNN HTP/System/GPU libraries (libQnnHtpV81Stub for sm8850).

BoardConfigCommon.mk: wire BOARD_SEPOLICY_DIRS to the common sepolicy/vendor directory for vendor file_contexts overrides.
---
 BoardConfigCommon.mk          |  1 +
 extract-files.py              | 15 +++++++++++++++
 sepolicy/vendor/file_contexts |  1 +
 3 files changed, 17 insertions(+)
 create mode 100644 sepolicy/vendor/file_contexts

diff --git a/BoardConfigCommon.mk b/BoardConfigCommon.mk
index 4aa4816..d084adb 100644
--- a/BoardConfigCommon.mk
+++ b/BoardConfigCommon.mk
@@ -218,6 +218,7 @@ VENDOR_SECURITY_PATCH := $(BOOT_SECURITY_PATCH)
 # SEPolicy
 include device/qcom/sepolicy_vndr/SEPolicy.mk
 include hardware/oplus/sepolicy/qti/SEPolicy.mk
+BOARD_SEPOLICY_DIRS += $(COMMON_PATH)/sepolicy/vendor
 
 # Verified Boot
 BOARD_AVB_ENABLE := true
diff --git a/extract-files.py b/extract-files.py
index 0939d63..e0e7933 100755
--- a/extract-files.py
+++ b/extract-files.py
@@ -155,6 +155,21 @@ blob_fixups: blob_fixups_user_type = {
         .replace_needed('libtensorflowlite_c.so', 'libtensorflowlite_c_vendor.so'),
     'vendor/usr/keylayout/gpio-keys.kl': blob_fixup()
         .add_line_if_missing('key 735   ASSIST'),
+    # APS turbo fix: on the port, the camera app's classloader namespace cannot dlopen the /odm
+    # ArcSoft/QNN helper libs (couple-HDR, turbo, QNN HTP), which gates the DSP/QNN path so turbo
+    # can't run. Exposing them as vendor public libraries lets the app namespace resolve them.
+    # Adapted from sm8750-common; infiniti uses QnnHtpV81Stub (not V79).
+    'vendor/etc/public.libraries.txt': blob_fixup()
+        .add_line_if_missing('libarcsoft_hdr_couple_api.so')
+        .add_line_if_missing('libarcsoft_high_dynamic_range_couple.so')
+        .add_line_if_missing('libarcsoft_smart_denoise.so')
+        .add_line_if_missing('libarcsoft_turbo_hdr_raw.so')
+        .add_line_if_missing('libarcsoft_turbo_raw.so')
+        .add_line_if_missing('libarcsoft_qnnhtp.so')
+        .add_line_if_missing('libQnnHtp.so')
+        .add_line_if_missing('libQnnSystem.so')
+        .add_line_if_missing('libQnnHtpV81Stub.so')
+        .add_line_if_missing('libQnnGpu.so'),
 }  # fmt: skip
 
 module = ExtractUtilsModule(
diff --git a/sepolicy/vendor/file_contexts b/sepolicy/vendor/file_contexts
new file mode 100644
index 0000000..e377fd0
--- /dev/null
+++ b/sepolicy/vendor/file_contexts
@@ -0,0 +1 @@
+# Vendor SELinux file_contexts overrides
