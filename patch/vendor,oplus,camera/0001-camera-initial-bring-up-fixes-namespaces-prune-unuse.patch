From 89b817fdef228287458ffcbab7bde3a1785f5905 Mon Sep 17 00:00:00 2001
From: "vivy@aosp-builder" <vivy@aosp-builder>
Date: Sun, 14 Jun 2026 17:27:28 +0000
Subject: [PATCH 01/10] camera: initial bring-up fixes (namespaces, prune
 unused blobs, sepolicy)

- extract-files.py: point namespace_imports and the SoC name at the infiniti
  target (sm8850). Disable the OplusCamera.apk and OppoGallery2.apk apktool
  patch series; those smali patches were authored against a different build's
  apks and reject against the obfuscated apks shipped here (the changes are
  cosmetic font/permission cleanup). The unit.sdk.jar shim patch is functional
  and applies cleanly, so it is retained.
- proprietary-files.txt: drop the bonito SoC sensor-config entries (cruft for a
  different SoC, absent on this device; sensors come from sm8850-common) and two
  shared-HAL libs that collide with the device tree
  (libfusioninterpolation.arcsoft, vendor.oplus.hardware.cammidasservice@1.0).
- sepolicy/vendor/file.te: proc_ufs_file was declared as both file_type and
  proc_type, which tripped the `neverallow domain proc_type:dir` rule via
  vendor_init's generic file_type:dir grant. Re-declared as fs_type, proc_type.
---
 extract-files.py        |   8 +-
 proprietary-files.txt   | 186 ----------------------------------------
 sepolicy/vendor/file.te |   3 +-
 3 files changed, 3 insertions(+), 194 deletions(-)

diff --git a/extract-files.py b/extract-files.py
index 9690796..5106165 100755
--- a/extract-files.py
+++ b/extract-files.py
@@ -55,12 +55,8 @@ lib_fixups: lib_fixups_user_type = {
 }
 
 blob_fixups = {
-    'system_ext/priv-app/OplusCamera/OplusCamera.apk': blob_fixup()
-        .apktool_patch('patches'),
     'system_ext/framework/com.oplus.camera.unit.sdk.jar': blob_fixup()
         .apktool_patch('patches-sdk'),
-    'system_ext/priv-app/OppoGallery2/OppoGallery2.apk': blob_fixup()
-        .apktool_patch('patches-gallery'),
     'odm/etc/init/init.camera_process.rc': blob_fixup()
         .regex_replace(
             '''on post-fs-data
@@ -88,8 +84,8 @@ on property:sys.camera.user.removed=*
 
 namespace_imports = [
     'vendor/oplus/camera/camera',
-    'vendor/oneplus/dodge',
-    'vendor/oneplus/sm8750-common',
+    'vendor/oneplus/infiniti',
+    'vendor/oneplus/sm8850-common',
     'hardware/oplus',
 ]
 
diff --git a/proprietary-files.txt b/proprietary-files.txt
index 159c9d7..d379afa 100644
--- a/proprietary-files.txt
+++ b/proprietary-files.txt
@@ -64,222 +64,37 @@ system_ext/priv-app/OplusAppPlatform/OplusAppPlatform.apk
