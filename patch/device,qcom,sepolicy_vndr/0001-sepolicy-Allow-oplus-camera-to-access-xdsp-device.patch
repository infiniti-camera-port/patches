From 88e6f2ba548edd5a88fcb707d8f45ce137a70895 Mon Sep 17 00:00:00 2001
From: Hecheng Yu <kde-yyds@qq.com>
Date: Fri, 27 Mar 2026 18:44:06 +0800
Subject: [PATCH 1/3] sepolicy: Allow oplus camera to access xdsp device

Change-Id: I39cf6e8a6af3ddf82a5e4c9383142b5dee1b1d2b
---
 generic/vendor/common/domain.te | 3 ++-
 1 file changed, 2 insertions(+), 1 deletion(-)

diff --git a/generic/vendor/common/domain.te b/generic/vendor/common/domain.te
index ef15b513..7bdbec8c 100644
--- a/generic/vendor/common/domain.te
+++ b/generic/vendor/common/domain.te
@@ -88,13 +88,14 @@ neverallow { domain
 - hal_sensors_default
 - hal_camera_default
 - hal_audio_default
+- opluscamera_app
 userdebug_or_eng(` -vendor_usta_app')
 userdebug_or_eng(` -vendor_ustaservice_app')
 userdebug_or_eng(` -vendor_sysmonapp_app_test')
 userdebug_or_eng(` -vendor_snapcam_app')
 }vendor_xdsp_device:chr_file *;
 
-neverallow { domain -init -vendor_init - ueventd } vendor_xdsp_device:chr_file ~{r_file_perms};
+neverallow { domain -init -vendor_init - ueventd -opluscamera_app } vendor_xdsp_device:chr_file ~{r_file_perms};
 
 neverallow { domain
 - init
