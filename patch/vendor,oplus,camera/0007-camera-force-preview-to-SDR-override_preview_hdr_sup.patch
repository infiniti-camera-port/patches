From b416847d8a2cf27baefc16f4e43d6ed8ea46f96a Mon Sep 17 00:00:00 2001
From: "vivy@aosp-builder" <1vivy@tutanota.com>
Date: Tue, 23 Jun 2026 23:15:52 +0000
Subject: [PATCH 07/10] camera: force preview to SDR
 (override_preview_hdr_support=false)

Fix the over-exposed preview: the camera app puts the preview on a BT2020_HLG
surface with 5.0 HDR/SDR headroom, but the sRGB panel has no HLG->SDR tonemap
path. Set persist.camera.override_enable=true and
persist.camera.override_preview_hdr_support=false so the preview SurfaceView
stays sRGB. The override is honored only when override_enable=true (read solely
by PreviewHDRControl), so there are no other side effects. Captured JPEGs are
unaffected; they are tonemapped on the provider side.
---
 opluscamera.mk | 9 +++++++++
 1 file changed, 9 insertions(+)

diff --git a/opluscamera.mk b/opluscamera.mk
index e763334..f65f9a4 100644
--- a/opluscamera.mk
+++ b/opluscamera.mk
@@ -21,8 +21,17 @@ PRODUCT_COPY_FILES += \
     $(LOCAL_PATH)/configs/init/init.oplus.camera_rus.rc:$(TARGET_COPY_OUT_SYSTEM_EXT)/etc/init/init.oplus.camera_rus.rc
 
 # Properties
+# Force preview to SDR. The camera app places the preview on a BT2020_HLG
+# SurfaceView with 5.0 HDR/SDR headroom (PreviewHDRControl); the sRGB panel has
+# no HLG->SDR tonemap path, so the preview is heavily over-exposed (captured
+# JPEGs are fine, they are tonemapped provider-side). Forcing the preview-HDR
+# capability off keeps the SurfaceView sRGB (numHdrLayers -> 0). The override is
+# honored only when override_enable=true, which is read solely by
+# PreviewHDRControl, so there are no other side effects.
 PRODUCT_PRODUCT_PROPERTIES += \
     persist.vendor.camera.privapp.list=com.oplus.camera \
+    persist.camera.override_enable=true \
+    persist.camera.override_preview_hdr_support=false \
     persist.sys.feature.dolby_vision=1 \
     persist.sys.feature.dolby_vision_app=1 \
     persist.sys.feature.hdr_vision_app=1 \
